# ─── terraform.tfvars.example ────────────────────────────────
# このファイルをコピーして terraform.tfvars を作成してください。
# terraform.tfvars は .gitignore に追加してください。
# cp terraform.tfvars.example terraform.tfvars

# ─── 共通 ─────────────────────────────────────────────────────
aws_region = "ap-northeast-1"
project    = "soc-ai"

# ─── ネットワーク ──────────────────────────────────────────────
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
availability_zones   = ["ap-northeast-1a", "ap-northeast-1c"]

# ─── ECS ───────────────────────────────────────────────────────
backend_image_tag      = "latest"
frontend_image_tag     = "latest"
backend_cpu            = 2048
backend_memory         = 8192
backend_desired_count  = 1
frontend_cpu           = 512
frontend_memory        = 1024
frontend_desired_count = 1

# ─── RDS ───────────────────────────────────────────────────────
# 既存RDSを使う場合（推奨）:
create_rds            = false
existing_rds_endpoint = "database-3.cdbaszsalwj8.ap-northeast-1.rds.amazonaws.com"
db_name               = "app_db"
db_username           = "app_user"

# 新規RDSを作成する場合:
# create_rds        = true
# db_instance_class = "db.t3.small"
# db_allocated_storage = 20

# ─── Secrets Manager ──────────────────────────────────────────
# 既存のSecrets ManagerのARNを指定してください
openai_secret_arn = "arn:aws:secretsmanager:ap-northeast-1:970835573274:secret:prod/openai/api-key-ctv4bB"
db_secret_arn     = "arn:aws:secretsmanager:ap-northeast-1:970835573274:secret:rds!db-3abb75b9-c579-47de-a978-d4f6e56dd4ba-kXjKwE"

# ─── ALB / HTTPS ──────────────────────────────────────────────
# ACM証明書のARN（HTTPSを使う場合のみ設定）
# certificate_arn = "arn:aws:acm:ap-northeast-1:970835573274:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
certificate_arn = ""

# ヘルスチェックパス
backend_health_check_path = "/health"
